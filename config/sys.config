%% Static config (no ${VAR} substitution, so no RELX_REPLACE_OS_VARS / awk).
%% The realm is set from HECATE_REALM in hecate_embedder_app:start/2; station
%% seeds come from MACULA_STATION_SEEDS (read by hecate_om directly); the model
%% dir from HECATE_EMBED_MODEL_DIR (read by hecate_embed directly).
[
    {hecate_om, [
        {service_cert_path, "/etc/hecate/secrets/service-cert.pem"},
        {health_port,       8480}
    ]},

    %% In-process real embedder (this runs on an AVX2 host).
    {hecate_embed, [
        {backend, nif}
    ]},

    {kernel, [
        {logger_level, info}
    ]}
].
