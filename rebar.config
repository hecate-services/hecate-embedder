%% -*- mode: erlang -*-
%% rebar3 configuration for hecate_embedder
%%
%% The sovereign sentence-embedding capability, ON THE MESH. An L2 hecate-om
%% service that advertises `io.hecate.embed' in the realm; peers reach it with
%% macula:call, location-transparently (no LAN address, works across subnets
%% where flat routing does not). Runs on an AVX2 host — the beam Celerons SIGILL
%% on the ONNX runtime — and does the actual embedding with the hecate_embed
%% library's real fastembed NIF.

{erl_opts, [debug_info, warnings_as_errors]}.

{deps, [
    %% The mesh substrate: macula client, realm membership, capability
    %% advertisement, /health. Same L2 base every hecate service boots on.
    {hecate_om, "~> 0.6"},
    %% The embedding library (text -> vector). Its Rustler NIF is built by the
    %% post_hook below with CARGO_FEATURES=real-embed (the container sets it).
    {hecate_embed, {git, "https://codeberg.org/hecate-social/hecate-embed.git", {branch, "main"}}}
]}.

%% Build hecate_embed's Rustler NIF after compile (it does not use rebar3_cargo).
%% The container exports CARGO_FEATURES=real-embed for the genuine ONNX embedder.
{post_hooks, [
    {compile, "bash _build/default/lib/hecate_embed/scripts/build-nif.sh"}
]}.

{project_plugins, [rebar3_ex_doc, rebar3_lint]}.

{relx, [
    %% hecate_om is `load'-only: included but not auto-started, so
    %% hecate_embedder_app:start/2 can set the realm before starting it.
    {release, {hecate_embedder, "0.1.0"}, [hecate_embedder, {hecate_om, load}, sasl]},
    {vm_args, "config/vm.args"},
    {sys_config, "config/sys.config"},
    {extended_start_script, true}
]}.

{profiles, [
    {prod, [{relx, [{mode, prod},
                    {include_src, false},
                    {include_erts, true},
                    {debug_info, strip}]}]}
]}.

{elvis, [
    {rulesets, #{
        macula_min => [
            {elvis_style, no_deep_nesting, #{level => 2}},
            {elvis_style, no_nested_try_catch, #{}},
            {elvis_style, no_if_expression, #{}}
        ]
    }},
    {config, [#{files => ["src/**/*.erl"], ruleset => macula_min}]}
]}.

{dialyzer, [
    {warnings, [no_unknown]},
    {exclude_apps, [
        macula, macula_envy, macula_mdns,
        reckon_db, reckon_evoq, reckon_gater, evoq,
        khepri, ra, horus, aten, seshat, gen_batch_server,
        gproc, msgpack, cowboy, ranch, jsx,
        hecate_embed
    ]}
]}.

{shell, [{apps, [hecate_embedder]}]}.

{ex_doc, [
    {source_url, <<"https://codeberg.org/hecate-services/hecate-embedder">>},
    {extras, ["README.md"]},
    {main, "README.md"}
]}.
